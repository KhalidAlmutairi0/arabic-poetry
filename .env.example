# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_password_here

# ── Meilisearch ───────────────────────────────────────
MEILISEARCH_MASTER_KEY=your_meili_master_key_here

# ── Security ──────────────────────────────────────────
SECRET_KEY=your_jwt_secret_key_min_32_chars_here

# ── Frontend (Vercel) ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Backend (copy to backend/.env) ────────────────────
DATABASE_URL=postgresql+asyncpg://poetry_user:POSTGRES_PASSWORD@localhost:5432/poetry_db
SYNC_DATABASE_URL=postgresql://poetry_user:POSTGRES_PASSWORD@localhost:5432/poetry_db
REDIS_URL=redis://localhost:6379/0
MEILISEARCH_URL=http://localhost:7700
OLLAMA_URL=http://localhost:11434
ENVIRONMENT=development
